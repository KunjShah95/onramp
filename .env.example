# ── Docker Compose Environment ───────────────────────────────────────────────
# Copy this file to .env and customize:
#   cp .env.example .env

# ── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=postgres_password

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_password

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-secret-min-32-chars
API_KEY_ENCRYPTION_KEY=change-me-to-32-chars-encryption-key

# ── LLM Providers (set at least one or many features won't work) ──────────────
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Frontend API URL (optional, defaults to /api/v1 for same-origin via Nginx proxy) ─
# In Docker, the frontend Nginx proxies /api/* to the backend, so /api/v1 works.
# For local dev (npm run dev), set to http://localhost:8000/api/v1.
VITE_API_URL=/api/v1

# ── Slack Integration ─────────────────────────────────────────────────────────
# Incoming webhook URL for sending channel messages (used by the standup bot
# and digest broadcasts). Create one at:
#   https://api.slack.com/apps -> Your App -> Incoming Webhooks
SLACK_WEBHOOK_URL=

# Bot token for proactive DMs (chat.postMessage) and interactive components.
# Needed for: standup reminders, acknowledgments, channel broadcasts.
# Create at:  https://api.slack.com/apps -> Your App -> OAuth & Permissions
# Scopes needed: chat:write, channels:read, groups:read
SLACK_BOT_TOKEN=

# Signing secret for verifying Slack request signatures on slash commands and
# interactive payloads. Found in your Slack app's Basic Information page.
SLACK_SIGNING_SECRET=

# Default channel for standup broadcasts and team digest posts.
SLACK_STANDUP_CHANNEL=#standups

# Time for daily standup reminders (24h UTC format). The Celery beat task
# will send proactive DMs at this time each day.
SLACK_STANDUP_TIME=10:00

# ── Seed / Demo config ───────────────────────────────────────────────────────
# Determines which teams get the Slack team digest broadcast.
# Can be a single team ID or left empty to auto-detect.
SLACK_TEAM_ID=
