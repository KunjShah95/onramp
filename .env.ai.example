# ============================================================================
# CodeFlow Universal AI Configuration
# ============================================================================
# This file shows ALL supported AI provider API keys.
# Configure at least 2-3 providers for redundancy and cost optimization.
#
# NO MODEL RESTRICTIONS - Use ANY model from ANY provider!
# ============================================================================

# ----------------------------------------------------------------------------
# RECOMMENDED: Ultra-Cheap Providers (Configure at least 1)
# ----------------------------------------------------------------------------
# These handle 60%+ of requests for maximum cost savings.

# DeepSeek - BEST VALUE for coding ($0.10/1M vs $2.50/1M for GPT-4o)
# Get key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Google Gemini - Large context (1-2M tokens), very cheap ($0.075/1M)
# Get key: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSy-your-gemini-key-here

# Groq - ULTRA FAST (500-800 tokens/sec), free tier available
# Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-key-here


# ----------------------------------------------------------------------------
# OPTIONAL: Premium Providers (Configure for complex/critical tasks)
# ----------------------------------------------------------------------------
# These are used for <10% of requests requiring high reasoning quality.

# OpenAI - GPT-4o, GPT-4o-mini, o1 reasoning models
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic - Claude 3.5 Sonnet (best reasoning), Opus, Haiku
# Get key: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# OpenRouter - Gateway to 200+ models from all providers
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here


# ----------------------------------------------------------------------------
# OPTIONAL: Additional Providers
# ----------------------------------------------------------------------------

# Mistral AI - European LLMs (Mistral Large, Small)
# Get key: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your-mistral-key-here

# Cohere - Command R, Rerank, Embed models
# Get key: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your-cohere-key-here

# Vercel AI SDK - Unified interface to multiple providers
# Get key: https://vercel.com/docs/ai-sdk
VERCEL_AI_SDK_API_KEY=your-vercel-ai-key-here

# Azure OpenAI - Enterprise GPT models with data residency
# Get from: https://portal.azure.com
AZURE_OPENAI_API_KEY=your-azure-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/


# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------

# Your application URL (for OpenRouter HTTP-Referer)
APP_URL=http://localhost:3000

# Cost optimization settings
PREFER_CHEAP_MODELS=true
ENABLE_PROVIDER_FALLBACKS=true
MAX_COST_PER_REQUEST=0.10


# ============================================================================
# RECOMMENDED SETUP FOR PRODUCTION
# ============================================================================
#
# Minimum (Cost-optimized):
# -------------------------
# 1. DEEPSEEK_API_KEY     (ultra-cheap coding model)
# 2. GEMINI_API_KEY       (large context, fast)
# 3. GROQ_API_KEY         (free tier, ultra fast)
#
# Balanced (Recommended):
# -----------------------
# 1. DEEPSEEK_API_KEY     (60% of requests - $0.10/1M)
# 2. GEMINI_API_KEY       (30% of requests - $0.075/1M)
# 3. OPENAI_API_KEY       (9% of requests - GPT-4o-mini $0.15/1M)
# 4. ANTHROPIC_API_KEY    (<1% critical - Claude $3/1M)
#
# Enterprise (Maximum reliability):
# ----------------------------------
# All providers configured for maximum redundancy and auto-fallback
#
# ============================================================================
# COST EXPECTATIONS
# ============================================================================
#
# With DeepSeek + Gemini + Groq (ultra-cheap providers):
# - 100,000 requests/month: ~$15-30/month
# - Savings vs GPT-4 only: 87-95%
#
# With balanced setup (including GPT-4o-mini for complex tasks):
# - 100,000 requests/month: ~$95-150/month
# - Savings vs GPT-4 only: 70-85%
#
# ============================================================================
# GETTING API KEYS (Quick Links)
# ============================================================================
#
# DeepSeek:    https://platform.deepseek.com/api_keys
# Gemini:      https://makersuite.google.com/app/apikey
# Groq:        https://console.groq.com/keys
# OpenAI:      https://platform.openai.com/api-keys
# Anthropic:   https://console.anthropic.com/account/keys
# OpenRouter:  https://openrouter.ai/keys
# Mistral:     https://console.mistral.ai/api-keys
# Cohere:      https://dashboard.cohere.com/api-keys
#
# ============================================================================
