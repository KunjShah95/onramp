# Firebase Configuration
# Get these values from your Firebase Console: Project Settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# API URL (optional, defaults to http://localhost:8000/api/v1)
VITE_API_URL=http://localhost:8000/api/v1

# Waitlist service base URL (optional, defaults to http://localhost:3008)
VITE_WAITLIST_URL=http://localhost:3008

# Set to "true" to use Firebase Emulator Suite for local development
VITE_USE_FIREBASE_EMULATORS=false
