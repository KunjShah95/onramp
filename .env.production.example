# ── Production Environment Variables ─────────────────────────────────────────
# Copy this to .env.production and fill in your values.
# Railway: add these in Dashboard > Project > Variables
# Vercel: add VITE_* prefixed vars in Dashboard > Project > Environment Variables

# ── Environment ──────────────────────────────────────────────────────────────
ENV=production
ENVIRONMENT=production

# ── Auth (Firebase Admin) ────────────────────────────────────────────────────
# Required for token verification on the backend.
# Get from Firebase Console > Project Settings > Service Accounts > Generate Key
FIREBASE_PROJECT_ID=your-firebase-project-id
# Option A: Path to service account JSON file (if mounted as a volume)
GOOGLE_APPLICATION_CREDENTIALS=
# Option B: Inline JSON (paste the entire service account key JSON here)
FIREBASE_SERVICE_ACCOUNT_JSON=
# Auth dev bypass MUST stay false in production
AUTH_DEV_BYPASS=false

# ── Database ─────────────────────────────────────────────────────────────────
# Railway provides a PostgreSQL URL automatically.
# If using Railway's built-in PostgreSQL plugin, it sets DATABASE_URL automatically.
# Otherwise, provide your own:
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/codeflow
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_SSL_MODE=require
DB_ECHO=false

# ── LLM Providers (free first, paid fallback) ────────────────────────────────
# Set at least one.
# Order: OpenRouter > Gemini > Groq > NVIDIA > OpenAI > Anthropic
OPENROUTER_API_KEY=sk-or-v1-your-key-here
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=
NVIDIA_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── GitHub ───────────────────────────────────────────────────────────────────
# Required for repo cloning and issue fetching
GITHUB_TOKEN=ghp_your-github-token

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated frontend origins allowed to call the API.
# Add your Vercel deployment URL here:
CORS_ALLOWED_ORIGINS=https://codeflow.vercel.app,https://your-custom-domain.com
# Railway adds a proxy — set this to true
TRUST_PROXY=true

# ── Redis (optional, for distributed rate limiting) ─────────────────────────
# If using Railway's Redis plugin, it sets REDIS_URL automatically.
REDIS_URL=

# ── Billing (Stripe) ─────────────────────────────────────────────────────────
# Optional. Leave unset for stub mode.
STRIPE_SECRET_KEY=sk_live_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_STARTUP=price_startup_id_from_stripe
STRIPE_PRICE_PROFESSIONAL=price_professional_id_from_stripe

# ── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-dsn@sentry.io/your-project

# ── Token Encryption ─────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GITHUB_TOKEN_ENCRYPTION_KEY=

# ── SendGrid (email) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@codeflow.ai
