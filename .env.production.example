# =============================================================================
# CodeFlow Production Environment Variables
# =============================================================================
# Copy this to .env.production and fill in actual values
# NEVER commit .env.production to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=CodeFlow
APP_VERSION=2.0.0
API_VERSION=v1

# Backend
BACKEND_URL=https://api.codeflow.ai
FRONTEND_URL=https://app.codeflow.ai

# Workers (adjust based on CPU cores: 2-4 x cores)
WORKERS=4
WEB_CONCURRENCY=4

# -----------------------------------------------------------------------------
# AI Providers
# -----------------------------------------------------------------------------
# PRIMARY: Gemini (recommended for cost)
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here

# FALLBACK: OpenRouter (multi-model access)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_APP_NAME=CodeFlow
OPENROUTER_SITE_URL=https://codeflow.ai

# OPTIONAL: Other providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Default model selection
DEFAULT_MODEL=gemini-1.5-flash
DEFAULT_MODEL_COMPLEX=gemini-1.5-pro

# -----------------------------------------------------------------------------
# Database & Storage
# -----------------------------------------------------------------------------
# Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your_client_id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# Firestore
FIRESTORE_EMULATOR_HOST=  # Empty for production

# PostgreSQL (if used)
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30

# -----------------------------------------------------------------------------
# Caching
# -----------------------------------------------------------------------------
# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5

# Cache settings
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE_MB=512

# -----------------------------------------------------------------------------
# Cost Optimization
# -----------------------------------------------------------------------------
# Token Budgets (daily limits)
DAILY_INPUT_TOKENS_LIMIT=50000000    # 50M tokens/day
DAILY_OUTPUT_TOKENS_LIMIT=10000000   # 10M tokens/day
USER_DAILY_INPUT_LIMIT=500000        # 500K tokens/user/day

# Budget alerts
COST_ALERT_THRESHOLD=50.0            # Alert if > $50/day
COST_ALERT_EMAIL=alerts@codeflow.ai
BUDGET_ALERT_PERCENT=80              # Alert at 80% usage
BUDGET_BLOCK_PERCENT=95              # Block at 95% usage

# Optimization features
ENABLE_PROMPT_COMPRESSION=true
ENABLE_REQUEST_DEDUPLICATION=true
ENABLE_REQUEST_BATCHING=true
ENABLE_AGGRESSIVE_CACHING=true
CACHE_AI_RESPONSES=true

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
GLOBAL_RATE_LIMIT_PER_MINUTE=1000
USER_RATE_LIMIT_PER_MINUTE=50
IP_RATE_LIMIT_PER_MINUTE=100

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# JWT
JWT_SECRET_KEY=your_long_random_secret_key_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS
CORS_ORIGINS=https://app.codeflow.ai,https://*.vercel.app
CORS_ALLOW_CREDENTIALS=true

# API Keys (for service-to-service)
API_KEY_HEADER=X-API-Key
SERVICE_API_KEYS=key1,key2,key3

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------
# Sentry (error tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Google Cloud Monitoring
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# Metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# Logging
LOG_FORMAT=json
LOG_FILE=/var/log/codeflow/app.log
LOG_ROTATION=daily
LOG_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# Email (for alerts)
# -----------------------------------------------------------------------------
# Resend
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=noreply@codeflow.ai

# SMTP fallback
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_TLS=true

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_TEAM_ANALYTICS=true
ENABLE_QUIZ_GENERATION=true
ENABLE_PLAYBOOKS=true
ENABLE_FIRST_PR_ACCELERATION=true
ENABLE_INTERACTIVE_TUTOR=true

# Experimental features
ENABLE_CODE_GENERATION=false
ENABLE_AUTO_PR_REVIEW=false

# -----------------------------------------------------------------------------
# Build & Deployment
# -----------------------------------------------------------------------------
VERSION=2.0.0
BUILD_DATE=2025-03-02
GIT_COMMIT=main

# Docker
DOCKER_REGISTRY=ghcr.io/codeflow
IMAGE_TAG=latest

# Ports
HTTP_PORT=80
HTTPS_PORT=443
BACKEND_PORT=8000

# -----------------------------------------------------------------------------
# Performance
# -----------------------------------------------------------------------------
# Connection pooling
MAX_KEEPALIVE_CONNECTIONS=100
KEEPALIVE_EXPIRY=5

# Timeouts
REQUEST_TIMEOUT=120
CONNECTION_TIMEOUT=30

# Limits
MAX_REQUEST_SIZE=20971520  # 20MB
MAX_CONCURRENT_REQUESTS=500

# -----------------------------------------------------------------------------
# Backup & Recovery
# -----------------------------------------------------------------------------
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
ENABLE_USAGE_ANALYTICS=true
ENABLE_COST_TRACKING=true

# -----------------------------------------------------------------------------
# Development URLs (for testing prod locally)
# -----------------------------------------------------------------------------
# LOCAL_BACKEND_URL=http://localhost:8000
# LOCAL_FRONTEND_URL=http://localhost:5173

# =============================================================================
# Cost Optimization Notes:
# =============================================================================
# 
# Target Monthly Cost: $200-500 for 10K users (vs $2000+ without optimization)
#
# Key Settings:
# 1. Use GEMINI_API_KEY (75% cheaper than OpenAI/Anthropic)
# 2. Enable all caching features
# 3. Set conservative token budgets
# 4. Enable request deduplication
# 5. Use flash models for 80% of requests
#
# Monitoring:
# - Track costs daily via /api/cost/summary
# - Set up budget alerts
# - Review optimization recommendations weekly
#
# =============================================================================
