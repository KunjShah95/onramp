# ── Environment ──────────────────────────────────────────────────────────────
# "production" | "development". Controls auth bypass, DB SSL defaults, migrations.
# ENV is preferred; ENVIRONMENT is accepted as a fallback.
ENV=development

# ── Auth (JWT / PostgreSQL) ──────────────────────────────────────────────────
# JWT signing secret. Use a strong random value in production.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=dev-jwt-secret-change-in-production
# Local-only escape hatch: accept unverified tokens as a dev user.
# Requires ENV != production. NEVER set true in production.
AUTH_DEV_BYPASS=false

# ── Database ─────────────────────────────────────────────────────────────────
# Required in production. asyncpg driver. (postgresql:// is auto-rewritten.)
DATABASE_URL=postgresql+asyncpg://onramp:postgres_password@localhost:5432/onramp
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
# disable | allow | prefer | require | verify-ca | verify-full
# Defaults to require in production, prefer otherwise.
DB_SSL_MODE=disable
DB_ECHO=false
# Set to "memory" to use the in-memory storage backend (tests/local, no DB).
STORAGE_BACKEND=

# ── LLM providers (free first, paid fallback) ────────────────────────────────
# Set any subset. Order: OpenRouter > Gemini > Groq > NVIDIA > OpenAI > Anthropic.
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── GitHub (repo cloning / issues) ───────────────────────────────────────────
GITHUB_TOKEN=

# ── HTTP / CORS / rate limiting ──────────────────────────────────────────────
# Comma-separated allowed origins for the frontend.
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Honor X-Forwarded-For (only behind a trusted proxy/load balancer).
TRUST_PROXY=false
# Optional: distributed rate limiting across workers. Falls back to in-memory.
REDIS_URL=

# ── Billing (Stripe) ─────────────────────────────────────────────────────────
# Optional. When unset, billing runs in metadata-only stub mode.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTUP=
STRIPE_PRICE_PROFESSIONAL=

# ── Email (SendGrid) ──────────────────────────────────────────────────────────
# Optional. When unset, email sending is a no-op.
SENDGRID_API_KEY=

# ── PII Encryption ─────────────────────────────────────────────────────────────
# Fernet key for encrypting email/name at rest. Required in production.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PII_ENCRYPTION_KEY=

# ── Monitoring ─────────────────────────────────────────────────────────────────
# Sentry DSN for error tracking (optional). When unset, sentry-sdk is a no-op.
SENTRY_DSN=
