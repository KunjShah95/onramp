# ─── Auth (Neon Auth / Better Auth) ────────────────────────────────────────
# Session verification uses neon_auth tables in PostgreSQL.
# No additional env vars needed beyond DATABASE_URL.

# ─── LLM Provider ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── GitHub ────────────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ─── Infrastructure (optional in dev — defaults in docker-compose) ─────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
DATABASE_URL=postgresql://codeflow:postgres_password@localhost:5432/codeflow

# ─── Security ──────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-32-char-string
API_KEY_ENCRYPTION_KEY=change-me-to-another-random-32-char-string
