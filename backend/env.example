# ─── Firebase / Firestore ──────────────────────────────────────────────────
# Set FIREBASE_PROJECT_ID (and optionally GOOGLE_APPLICATION_CREDENTIALS) to
# use real Firestore.  When either is missing the services fall back to
# in-memory storage, so development always works.
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
# Alternatively, paste the full service-account JSON inline:
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── LLM Provider ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── GitHub ────────────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ─── Infrastructure (optional in dev — defaults in docker-compose) ─────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
DATABASE_URL=postgresql://codeflow:postgres_password@localhost:5432/codeflow

# ─── Security ──────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-32-char-string
API_KEY_ENCRYPTION_KEY=change-me-to-another-random-32-char-string
