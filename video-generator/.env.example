# Video Generation API Keys
# Choose one or more providers

# Option 1: Google Veo via inference.sh
INFSH_API_KEY=your_infsh_api_key_here

# Option 2: RunComfy (when available on Windows)
RUNCOMFY_TOKEN=your_runcomfy_token_here

# Option 3: ElevenLabs for voiceover
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Option 4: OpenAI for additional AI features
OPENAI_API_KEY=your_openai_api_key_here

# Output settings
OUTPUT_DIR=./output
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_FPS=30
